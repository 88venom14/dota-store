{
  "expo": {
    "name": "Dota 2 Items Store",
    "slug": "dota-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dotastore",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.loveletter.dotastore"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B0D",
          "image": "./assets/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to set a profile avatar."
        }
      ]
    ],
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bbb1d2e2-cee7-456b-b947-b69f72f0b242"
      }
    },
    "owner": "loveletter"
  }
}
